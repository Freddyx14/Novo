# ============================================================
# NOVO - Configuración de Variables de Entorno
# ============================================================
# IMPORTANTE: 
#   1. Copia este archivo: cp .env.example .env (Linux/Mac)
#                    o:   Copy-Item .env.example .env (Windows)
#   2. Reemplaza los valores con tus credenciales reales
#   3. NUNCA hagas commit del archivo .env
#    (ya está en .gitignore)
# ============================================================

# --- Supabase (Base de datos + Autenticación) ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_supabase_anon_public_key

# --- Flask ---
SECRET_KEY=genera_una_clave_con: python -c "import secrets; print(secrets.token_hex(32))"

# --- Google Gemini API (Análisis IA de CV + Audio) ---
GEMINI_API_KEY=tu_gemini_api_key_aqui

# --- Alternativamente (Google generativeai deprecado) ---
# GOOGLE_API_KEY=tu_google_api_key_aqui

# --- Perplexity API (Búsqueda web de oportunidades) ---
PERPLEXITY_API_KEY=tu_perplexity_api_key_aqui

# --- Stripe (Pagos - Plan Premium) ---
STRIPE_SECRET_KEY=tu_stripe_secret_key_aqui
STRIPE_PRICE_ID=tu_stripe_price_id_aqui

# --- Demo Account (Para testing - AISLADO de usuarios reales) ---
DEMO_EMAIL=demo@novo.app
DEMO_PASSWORD=tu_demo_password_aqui
